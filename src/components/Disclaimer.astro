---
---
<div id="bci-disclaimer-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-md p-4 hidden transition-opacity duration-500 ease-in-out">
  <div class="max-w-2xl w-full bg-white border border-amber-500/30 rounded-lg shadow-2xl p-6 md:p-8 transform transition-transform duration-500 scale-95 opacity-0" id="disclaimer-content">
    <div class="text-center mb-6">
      <div class="text-amber-600 text-xs font-semibold tracking-widest uppercase mb-2 font-sans">Bar Council of India Compliance</div>
      <h2 class="text-3xl font-serif-legal font-semibold text-slate-900 tracking-wide">Disclaimer & Acknowledgment</h2>
      <div class="h-0.5 w-16 bg-amber-550/80 mx-auto mt-4"></div>
    </div>
    
    <div class="text-slate-700 text-sm md:text-base leading-relaxed space-y-4 max-h-[60vh] overflow-y-auto pr-2 mb-8 font-sans">
      <p>
        Under the rules of the Bar Council of India, <strong>DNA Legal (Advocates & Solicitors)</strong> is prohibited from advertising and soliciting work in any form or manner. By clicking the "I Agree" button below and accessing this website, the user acknowledges and confirms the following:
      </p>
      <ul class="list-disc pl-5 space-y-2 text-slate-600">
        <li>The user wishes to gain more information about DNA Legal, its practice areas, and its team members for their own information and personal use.</li>
        <li>No solicitation, advertisement, personal communication, invitation, or inducement of any sort has been made by or on behalf of DNA Legal or any of its members to solicit work through this website.</li>
        <li>The information provided on this website is made available to the user only on their specific request, and any transmission, receipt, or use of this website does not create any attorney-client relationship.</li>
        <li>The information on this website is provided solely for informational purposes and should not be interpreted or construed as legal advice or solicitation.</li>
        <li>DNA Legal is not liable for any consequence of any action taken by the user relying on material/information provided on this website.</li>
      </ul>
      <p class="text-slate-500 text-xs italic mt-4 border-t border-slate-200 pt-4">
        If you do not agree to these terms, please click "Decline" to exit this website.
      </p>
    </div>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-end font-sans">
      <button 
        id="btn-decline-disclaimer" 
        class="px-6 py-2.5 rounded border border-slate-300 text-slate-600 hover:text-slate-900 hover:bg-slate-100 hover:border-slate-400 transition-all text-sm font-medium tracking-wider uppercase cursor-pointer text-center"
      >
        Decline
      </button>
      <button 
        id="btn-accept-disclaimer" 
        class="px-8 py-2.5 rounded bg-gradient-to-r from-amber-600 to-amber-500 text-slate-950 font-semibold hover:from-amber-650 hover:to-amber-550 hover:shadow-lg hover:shadow-amber-500/10 transition-all text-sm tracking-wider uppercase cursor-pointer text-center"
      >
        I Agree & Enter
      </button>
    </div>
  </div>
</div>

<script>
  function initDisclaimer() {
    const modal = document.getElementById('bci-disclaimer-modal');
    const content = document.getElementById('disclaimer-content');
    const btnAccept = document.getElementById('btn-accept-disclaimer');
    const btnDecline = document.getElementById('btn-decline-disclaimer');
    
    if (!modal || !content) return;
    
    const isAccepted = localStorage.getItem('dna-legal-disclaimer-accepted');
    
    if (!isAccepted) {
      // Show modal
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      // Trigger animation next frame
      requestAnimationFrame(() => {
        modal.classList.add('opacity-100');
        content.classList.remove('scale-95', 'opacity-0');
        content.classList.add('scale-100', 'opacity-100');
      });
    }
    
    btnAccept?.addEventListener('click', () => {
      localStorage.setItem('dna-legal-disclaimer-accepted', 'true');
      
      // Animate out
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0');
      content.classList.remove('scale-100', 'opacity-100');
      content.classList.add('scale-95', 'opacity-0');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }, 500);
    });
    
    btnDecline?.addEventListener('click', () => {
      window.location.href = 'https://www.google.com';
    });
  }

  // Run on page load and after Astro swaps pages (View Transitions)
  window.addEventListener('DOMContentLoaded', initDisclaimer);
  document.addEventListener('astro:after-swap', initDisclaimer);
</script>
