---
interface Props {
  title: string;
  icon?: string;
  description: string;
  subpractice?: string[];
  link?: string;
}

const { title, icon = "scale", description, subpractice = [] } = Astro.props;
---

<div class="relative overflow-hidden bg-slate-900 border border-slate-800 hover:border-amber-500/30 rounded-lg p-6 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg hover:shadow-amber-500/5 group flex flex-col justify-between h-full">
  <!-- Glowing subtle gradient in background on hover -->
  <div class="absolute -inset-px bg-gradient-to-r from-amber-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-lg pointer-events-none"></div>

  <div>
    <!-- Icon Container -->
    <div class="inline-flex items-center justify-center p-3 rounded-lg bg-slate-950 border border-slate-800 text-amber-500 group-hover:border-amber-500/40 transition-colors duration-300 mb-5">
      {icon === "scale" && (
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
        </svg>
      )}
      {icon === "briefcase" && (
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      )}
      {icon === "building" && (
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
      )}
      {icon === "shield" && (
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.952 11.952 0 01-7.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      )}
      {icon === "bank" && (
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
        </svg>
      )}
      {icon === "user" && (
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      )}
      {icon === "tax" && (
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
      )}
    </div>

    <!-- Title -->
    <h3 class="font-serif-legal text-xl font-bold text-slate-100 tracking-wide mb-3 group-hover:text-amber-400 transition-colors">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-slate-400 text-sm leading-relaxed mb-5 font-sans">
      {description}
    </p>

    <!-- Sub-practices -->
    {subpractice.length > 0 && (
      <div class="border-t border-slate-800/80 pt-4 mt-2">
        <h4 class="text-xs font-semibold text-amber-500/80 tracking-wider uppercase mb-2">Core Areas</h4>
        <ul class="space-y-1.5 font-sans">
          {subpractice.map((item) => (
            <li class="text-xs text-slate-400 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-500/60 flex-shrink-0"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</div>
