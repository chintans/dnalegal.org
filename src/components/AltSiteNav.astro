---
interface Props {
  active?: string;
}
const { active = 'home' } = Astro.props;

const cur = (k: string) => active === k ? 'page' : undefined;
---
<nav class="site-nav" data-open="false">
  <div class="site-nav__bar">
    <a class="site-nav__brand" href="/altA">
      <span class="site-nav__mark">DNA<b>.</b>LEGAL</span>
      <span class="site-nav__sub">Advocates · Solicitors</span>
    </a>
    <div class="site-nav__links">
      <a href="/altA" aria-current={cur('home')}>Home</a>
      <a href="/altA/about" aria-current={cur('about')}>Firm</a>
      <a href="/altA/practice" aria-current={cur('practice')}>Practice</a>
      <a href="/altA/team" aria-current={cur('team')}>Team</a>
      <a href="/altA/clients" aria-current={cur('clients')}>Clients</a>
      <a href="/altA/insights" aria-current={cur('insights')}>Insights</a>
      <a href="/altA/contact" aria-current={cur('contact')}>Contact</a>
    </div>
    <a class="btn btn-primary site-nav__cta" href="/altA/contact">Contact us</a>
    <button type="button" class="btn btn-secondary btn-icon site-nav__burger" aria-label="Menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
  </div>
</nav>

<style>
  :root { --edge: clamp(20px, 5vw, 72px); }
  .site-nav { position: sticky; top: 0; z-index: 50; background: var(--color-bg); font-family: var(--font-body); }
  .site-nav__bar { display: flex; align-items: center; gap: clamp(16px, 2.4vw, 36px); padding: 18px var(--edge); border-bottom: 2px solid var(--color-divider); }
  .site-nav__brand { display: flex; flex-direction: column; line-height: 1; text-decoration: none; color: var(--color-text); margin-right: auto; }
  .site-nav__mark { font-family: var(--font-heading); font-weight: 800; font-size: 22px; letter-spacing: -0.01em; }
  .site-nav__mark b { color: var(--color-accent); }
  .site-nav__sub { font-size: 9px; letter-spacing: 0.34em; text-transform: uppercase; margin-top: 5px; color: color-mix(in srgb, var(--color-text) 60%, transparent); }
  .site-nav__links { display: flex; align-items: center; gap: clamp(14px, 1.8vw, 26px); }
  .site-nav__links a { font-size: 12.5px; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; color: color-mix(in srgb, var(--color-text) 72%, transparent); padding: 6px 0; }
  .site-nav__links a:hover { color: var(--color-text); }
  .site-nav__links a[aria-current="page"] { color: var(--color-accent); box-shadow: inset 0 -2px 0 var(--color-accent); }
  .site-nav__cta { margin-left: 6px; }
  .site-nav__burger { display: none; }
  @media (max-width: 900px) {
    .site-nav__links, .site-nav__cta { display: none; }
    .site-nav__burger { display: inline-flex; }
    .site-nav[data-open="true"] .site-nav__links { display: flex; flex-direction: column; align-items: flex-start; gap: 0; padding: 8px var(--edge) 20px; border-bottom: 2px solid var(--color-divider); }
    .site-nav[data-open="true"] .site-nav__links a { width: 100%; padding: 13px 0; border-top: 1px solid var(--color-divider); }
    .site-nav[data-open="true"] .site-nav__cta { display: inline-flex; margin: 12px var(--edge) 0; }
  }
</style>

<script>
  const burger = document.querySelector('.site-nav__burger');
  const nav = document.querySelector('.site-nav');
  if (burger && nav) {
    burger.addEventListener('click', () => {
      const isOpen = nav.getAttribute('data-open') === 'true';
      nav.setAttribute('data-open', isOpen ? 'false' : 'true');
    });
  }
</script>
