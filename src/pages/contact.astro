---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us">
  <!-- Page Header -->
  <section class="relative py-20 bg-slate-950 border-b border-slate-900">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_-10%,rgba(197,168,128,0.05),rgba(255,255,255,0))]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative text-center">
      <span class="text-xs font-semibold uppercase tracking-widest text-amber-500 block mb-3">Reach Our Offices</span>
      <h1 class="text-4xl md:text-5xl font-serif-legal font-bold text-white tracking-wide">
        Presence & Contact
      </h1>
      <p class="mt-4 max-w-xl mx-auto text-slate-400 text-sm md:text-base leading-relaxed">
        Get in touch with our team in New Delhi. Access is subject to BCI rules and regulations.
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-20 bg-slate-950 font-sans">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        
        <!-- Left: Offices and Memberships -->
        <div class="lg:col-span-5 space-y-10">
          
          <!-- Locations -->
          <div class="space-y-6">
            <h2 class="text-xs font-bold uppercase tracking-widest text-amber-500 border-b border-slate-900 pb-2">Our Presence</h2>
            
            <!-- New Delhi Office -->
            <div class="space-y-2">
              <h3 class="font-serif-legal text-xl font-bold text-slate-100">Principal Office — New Delhi</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                4A, Mathura Road, Jangpura-A,<br />
                New Delhi - 110014, India
              </p>
            </div>

            <!-- Supreme Court Chambers -->
            <div class="space-y-2">
              <h3 class="font-serif-legal text-xl font-bold text-slate-100">Supreme Court of India</h3>
              <p class="text-slate-400 text-sm leading-relaxed">
                Chamber No. 101, A. K. Sen Block,<br />
                Supreme Court of India, New Delhi
              </p>
            </div>

            <!-- Telephone -->
            <div class="pt-4 border-t border-slate-900 flex items-center gap-3">
              <div class="text-amber-500">
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div class="text-sm">
                <span class="text-slate-500 font-medium">Landline:</span> 
                <a href="tel:+911135569976" class="text-slate-200 hover:text-amber-400 transition-colors ml-1 font-semibold">+91 11 3556 9976</a>
              </div>
            </div>
          </div>

          <!-- Professional Memberships -->
          <div class="space-y-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-amber-500 border-b border-slate-900 pb-2">Bar & Professional Memberships</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-2 text-xs text-slate-400 font-sans">
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500/70"></span>
                <span>Supreme Court Bar Association (SCBA)</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500/70"></span>
                <span>Bar Council of Delhi</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500/70"></span>
                <span>Bar Council of Punjab and Haryana</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500/70"></span>
                <span>Delhi High Court Bar Association (DHCBA)</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500/70"></span>
                <span>NCLT and NCLAT Bar Association</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500/70"></span>
                <span>Insolvency & Bankruptcy Board (IBBI)</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500/70"></span>
                <span>Delhi Bar Association & NDBA</span>
              </li>
            </ul>
          </div>

        </div>

        <!-- Right: Contact Form with Compliance Acknowledgement -->
        <div class="lg:col-span-7 bg-slate-900 border border-slate-800 rounded-lg p-6 md:p-8 space-y-6">
          <div>
            <h2 class="font-serif-legal text-2xl font-bold text-white tracking-wide mb-2">Send an Inquiry</h2>
            <p class="text-xs text-slate-400 leading-relaxed">
              If you require informational details regarding our team or presence, please use the form below. Under BCI guidelines, we do not accept solicitation messages.
            </p>
          </div>

          <form id="contact-form" class="space-y-4 font-sans text-sm">
            <div>
              <label for="name" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-2">Full Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                class="w-full bg-slate-950 border border-slate-800 focus:border-amber-500/50 rounded p-3 text-slate-200 focus:outline-none transition-colors"
                placeholder="Your Name"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-2">Email Address</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required 
                  class="w-full bg-slate-950 border border-slate-800 focus:border-amber-500/50 rounded p-3 text-slate-200 focus:outline-none transition-colors"
                  placeholder="name@organization.com"
                />
              </div>
              <div>
                <label for="org" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-2">Organization (Optional)</label>
                <input 
                  type="text" 
                  id="org" 
                  name="org" 
                  class="w-full bg-slate-950 border border-slate-800 focus:border-amber-500/50 rounded p-3 text-slate-200 focus:outline-none transition-colors"
                  placeholder="Company Name"
                />
              </div>
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-2">Nature of Inquiry</label>
              <textarea 
                id="message" 
                name="message" 
                rows="4" 
                required 
                class="w-full bg-slate-950 border border-slate-800 focus:border-amber-500/50 rounded p-3 text-slate-200 focus:outline-none transition-colors resize-none"
                placeholder="Please state the factual information or credentials you wish to verify."
              ></textarea>
            </div>

            <!-- BCI Consent Checkbox -->
            <div class="relative flex items-start py-3 border-t border-slate-800/80 mt-2">
              <div class="flex items-center h-5">
                <input 
                  id="bci-consent" 
                  name="bci-consent" 
                  type="checkbox" 
                  required
                  class="focus:ring-amber-500/20 h-4 w-4 text-amber-600 border-slate-800 bg-slate-950 rounded cursor-pointer"
                />
              </div>
              <div class="ml-3 text-xs leading-relaxed">
                <label for="bci-consent" class="font-medium text-slate-300 cursor-pointer select-none">
                  I Acknowledge BCI Compliance Rules
                </label>
                <p class="text-slate-500 text-[10px]">
                  By submitting, I confirm that this inquiry is made of my own volition and does not create an attorney-client relationship. No advertisement or solicitation has induced me to reach out.
                </p>
              </div>
            </div>

            <button 
              type="submit" 
              class="w-full px-6 py-3 rounded bg-gradient-to-r from-amber-600 to-amber-500 text-slate-950 font-bold hover:from-amber-550 hover:to-amber-450 hover:shadow-lg hover:shadow-amber-500/10 transition-all uppercase text-xs tracking-widest cursor-pointer text-center"
            >
              Submit Inquiry
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

  <script>
    function setupContactForm() {
      const form = document.getElementById('contact-form');
      form?.addEventListener('submit', (e) => {
        e.preventDefault();
        alert('Thank you for your message. Your inquiry has been received in compliance with BCI guidelines. Our team will contact you if appropriate.');
        form.reset();
      });
    }

    window.addEventListener('DOMContentLoaded', setupContactForm);
    document.addEventListener('astro:after-swap', setupContactForm);
  </script>
</BaseLayout>
