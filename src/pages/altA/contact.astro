---
import AltLayout from '../../layouts/AltLayout.astro';
---

<AltLayout title="Contact Us" activeNav="contact" showCta={false}>
  <hr class="rule2">
  <div class="wrap">
    <header class="ph">
      <div>
        <p class="ph__k">Contact</p>
        <h1>Speak to a partner.</h1>
      </div>
      <p class="ph__lead">Tell us about your matter. Every enquiry is reviewed by a partner, and you'll deal with the lawyer who knows your file from the first conference onward.</p>
    </header>
  </div>
  <div class="wrap">
    <div class="body">
      <div class="formcol">
        <h2>Send an enquiry</h2>
        <p class="intro">Please share a brief outline. Do not include confidential or privileged information in this form.</p>
        <form id="contact-form">
          <div class="form-grid">
            <div class="field"><label for="c-name">Full name</label><input class="input" id="c-name" required></div>
            <div class="field"><label for="c-org">Organisation</label><input class="input" id="c-org"></div>
            <div class="field"><label for="c-email">Email</label><input class="input" id="c-email" type="email" required></div>
            <div class="field"><label for="c-phone">Phone</label><input class="input" id="c-phone" type="tel"></div>
            <div class="field full"><label for="c-matter">Nature of matter</label>
              <select class="select" id="c-matter">
                <option>Commercial Disputes &amp; Recovery</option>
                <option>Commercial Arbitration</option>
                <option>Constitutional &amp; Taxation</option>
                <option>Real Estate</option>
                <option>Insolvency &amp; Bankruptcy</option>
                <option>Banking &amp; Finance</option>
                <option>Private Client Practice</option>
                <option>White Collar &amp; Economic Offences</option>
                <option>Other / Not sure</option>
              </select>
            </div>
            <div class="field full"><label for="c-msg">Brief description of your matter</label><textarea class="input" id="c-msg" rows="5" required></textarea></div>
          </div>
          <button class="btn btn-primary btn-block" type="submit" style="justify-content:flex-start;">Submit enquiry →</button>
          <p class="form-note">This is a demonstration form and does not transmit data. Submitting an enquiry does not create a lawyer-client relationship.</p>
        </form>
      </div>
      <aside class="info">
        <div class="office">
          <h3>Principal Office — New Delhi</h3>
          <p>4A, Mathura Road, Jangpura-A,<br>New Delhi – 110014, India</p>
        </div>
        <div class="office">
          <h3>Supreme Court of India</h3>
          <p>Chamber No. 101, A. K. Sen Block,<br>Supreme Court of India, New Delhi</p>
        </div>
        <div class="office">
          <h3>Reach us</h3>
          <p><a href="tel:+911135569976">+91 11 3556 9976</a><br><a href="mailto:contact@dnalegal.in">contact@dnalegal.in</a></p>
        </div>
        <div class="office" style="border-bottom:0;">
          <h3>Pan-India Network</h3>
          <p>A vetted network of associate counsel before every major High Court, NCLT bench, DRT, Commercial Court and RERA authority — supervised from New Delhi.</p>
        </div>
        <div class="mapfig grayscale">
          <image-slot id="contact-map" shape="rect" placeholder="Map — Jangpura-A, New Delhi"></image-slot>
          <p class="mapfig__cap">4A Mathura Road, Jangpura-A · New Delhi 110014</p>
        </div>
      </aside>
    </div>
  </div>
  <section class="mem">
    <div class="wrap">
      <h2>Bar &amp; professional memberships.</h2>
      <div class="mem__grid">
        <span class="mem__c">Supreme Court Bar Association (SCBA)</span>
        <span class="mem__c">Bar Council of Delhi</span>
        <span class="mem__c">Bar Council of Punjab &amp; Haryana</span>
        <span class="mem__c">Delhi High Court Bar Association</span>
        <span class="mem__c">NCLT &amp; NCLAT Bar Association</span>
        <span class="mem__c">IBBI — Registered Insolvency Professional</span>
        <span class="mem__c">Delhi Bar Association</span>
        <span class="mem__c">New Delhi Bar Association</span>
      </div>
    </div>
  </section>
</AltLayout>

<style>
  .ph { padding: clamp(48px,6vw,96px) 0 clamp(40px,5vw,64px); display: grid; grid-template-columns: minmax(0,1fr) minmax(0,0.9fr); gap: 32px clamp(32px,5vw,72px); align-items: end; }
  .ph__k { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-accent-700); margin: 0 0 22px; }
  .ph h1 { font-size: clamp(42px,6vw,84px); line-height: 0.98; letter-spacing: -0.03em; margin: 0; }
  .ph__lead { font-size: clamp(16px,1.5vw,20px); line-height: 1.6; margin: 0; color: color-mix(in srgb, var(--color-text) 82%, transparent); max-width: 48ch; }
  .body { display: grid; grid-template-columns: 1.1fr 1fr; gap: 8px clamp(40px,6vw,96px); align-items: start; padding: clamp(44px,5vw,72px) 0 clamp(56px,7vw,96px); }
  .formcol h2 { font-size: clamp(22px,2.4vw,30px); letter-spacing: -0.01em; margin: 0 0 8px; }
  .formcol .intro { font-size: 15px; line-height: 1.6; margin: 0 0 28px; color: color-mix(in srgb,var(--color-text) 74%,transparent); max-width: 46ch; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .form-grid .field.full { grid-column: 1 / -1; }
  .select { -webkit-appearance: none; appearance: none; width: 100%; min-height: 42px; padding: 8px 12px; font: inherit; font-size: 14px; color: var(--color-text); background: var(--color-surface); border: 1px solid var(--color-divider); border-radius: 0; cursor: pointer; }
  .field label { font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: color-mix(in srgb,var(--color-text) 62%,transparent); }
  .form-note { font-size: 12px; line-height: 1.6; color: color-mix(in srgb,var(--color-text) 55%,transparent); margin: 18px 0 0; }
  .info { display: flex; flex-direction: column; gap: 2px; }
  .office { border-top: 2px solid var(--color-divider); padding: 26px 0; }
  .office h3 { font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-accent-700); margin: 0 0 14px; }
  .office p { font-size: 15.5px; line-height: 1.6; margin: 0; color: color-mix(in srgb,var(--color-text) 86%,transparent); }
  .office a { text-decoration: none; }
  .office a:hover { text-decoration: underline; }
  .mapfig { aspect-ratio: 3/2; margin-top: 8px; border-top: 2px solid var(--color-divider); padding-top: 26px; }
  .mapfig image-slot { width: 100%; aspect-ratio: 3/2; }
  .mapfig__cap { font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: color-mix(in srgb,var(--color-text) 55%,transparent); margin: 12px 0 0; }
  .mem { background: var(--color-text); color: var(--color-bg); }
  .mem .wrap { padding: clamp(48px,6vw,80px) var(--edge); }
  .mem h2 { color: var(--color-bg); font-size: clamp(24px,2.8vw,36px); letter-spacing: -0.02em; margin: 0 0 36px; max-width: 22ch; }
  .mem__grid { display: flex; flex-wrap: wrap; gap: 12px; }
  .mem__c { font-size: 14px; padding: 12px 18px; border: 1px solid color-mix(in srgb,#fff 26%,transparent); color: color-mix(in srgb,#fff 88%,transparent); }
  @media (max-width: 820px) { .ph { grid-template-columns: 1fr; align-items: start; } .body { grid-template-columns: 1fr; } .form-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.innerHTML = `
        <div style="border-top:2px solid var(--color-divider);padding-top:28px;">
          <h3 style="color:var(--color-accent-700);margin:0 0 10px;font-size:22px;">Thank you — your enquiry has been noted.</h3>
          <p style="margin:0;font-size:15px;color:color-mix(in srgb,var(--color-text) 76%,transparent);max-width:46ch;line-height:1.6;">
            A partner will review your matter and respond shortly. In this demonstration, no data has been transmitted.
          </p>
        </div>
      `;
    });
  }
</script>
